rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isThreadParticipant(thread) {
      return signedIn() && request.auth.uid in thread.data.participantIds;
    }

    match /chatThreads/{threadId} {
      allow read: if isThreadParticipant(resource);

      allow create: if signedIn()
        && request.auth.uid in request.resource.data.participantIds
        && request.resource.data.participantIds is list
        && request.resource.data.contextType in ['match', 'complex', 'direct'];

      allow update, delete: if false;

      match /messages/{messageId} {
        allow read: if isThreadParticipant(get(/databases/$(database)/documents/chatThreads/$(threadId)));

        allow create: if isThreadParticipant(get(/databases/$(database)/documents/chatThreads/$(threadId)))
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string;

        allow update, delete: if false;
      }
    }
  }
}
